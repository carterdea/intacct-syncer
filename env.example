# Intacct OAuth (per environment)
INTACCT_AUTH_URL_PROD=
INTACCT_AUTH_URL_DEV=
INTACCT_API_BASE_PROD=
INTACCT_API_BASE_DEV=
INTACCT_COMPANY_ID_PROD=
INTACCT_COMPANY_ID_DEV=
INTACCT_CLIENT_ID_PROD=
INTACCT_CLIENT_SECRET_PROD=
INTACCT_CLIENT_ID_DEV=
INTACCT_CLIENT_SECRET_DEV=
INTACCT_USERNAME_PROD=Admin
INTACCT_USERNAME_DEV=Admin
INTACCT_ENTITY_ID_PROD=   # optional; omit or leave empty to skip
INTACCT_ENTITY_ID_DEV=    # optional; omit or leave empty to skip

# Optional OAuth scopes (space-separated), e.g.:
# Example: iaapi:company:<COMPANY_ID> iaapi:user:<USER_OR_USERKEY>
INTACCT_OAUTH_SCOPE_PROD=
INTACCT_OAUTH_SCOPE_DEV=

# App DB
INTACCTSYNC_DB=intacctsync.sqlite3

# Tuning
INTACCT_HTTP_TIMEOUT=30
INTACCT_PAGE_SIZE=200
